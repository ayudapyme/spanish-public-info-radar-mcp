# Spanish Public Data MCP - Environment Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# MCP Server Configuration
# =============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Directory for tool call logs (default: ./logs)
MCP_LOGS_DIR=./logs

# =============================================================================
# HTTP Client Configuration
# =============================================================================
# Connection timeout in seconds (default: 10)
HTTP_TIMEOUT_CONNECT=10.0

# Read timeout in seconds (default: 30)
HTTP_TIMEOUT_READ=30.0

# Write timeout in seconds (default: 10)
HTTP_TIMEOUT_WRITE=10.0

# Connection pool timeout in seconds (default: 10)
HTTP_TIMEOUT_POOL=10.0

# =============================================================================
# Retry Configuration
# =============================================================================
# Maximum number of retry attempts (default: 3)
HTTP_MAX_RETRIES=3

# Minimum wait between retries in seconds (default: 1)
HTTP_RETRY_MIN_WAIT=1

# Maximum wait between retries in seconds (default: 10)
HTTP_RETRY_MAX_WAIT=10

# =============================================================================
# Logging
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable JSON structured logging (default: false)
LOG_JSON_FORMAT=false

# Log retention in days (default: 7)
LOG_RETENTION_DAYS=7
